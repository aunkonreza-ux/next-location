# ─────────────────────────────────────────────────────────────────────────────
# Next Location — Environment Variables
# Copy this file to ".env.local" and fill in the values. NOTHING here is secret
# unless noted; anything prefixed with NEXT_PUBLIC_ is visible in the browser.
# The site runs perfectly fine with these left blank — sensible fallbacks apply.
# ─────────────────────────────────────────────────────────────────────────────

# The full public URL of your live site (used for SEO, sitemap, social cards).
# Example: https://nextlocation.com.bd
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Contact channels shown across the site.
NEXT_PUBLIC_WHATSAPP_NUMBER=+8801XXXXXXXXX
NEXT_PUBLIC_PHONE=+8801XXXXXXXXX
NEXT_PUBLIC_EMAIL=info@nextlocation.com.bd

# Social profile links (leave blank to hide the icon).
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Optional analytics IDs. Leave blank to disable — the site never crashes if absent.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# Server-only: where contact/inquiry/valuation form submissions should be emailed.
# (No email is actually sent until you wire a provider — submissions are logged.)
CONTACT_FORM_TARGET_EMAIL=info@nextlocation.com.bd

# Area-unit conversion. Bangladesh uses both sqft and katha. We store sqft as the
# source of truth and convert for display. This value is configurable on purpose:
# katha size is NOT universally standardised across Bangladesh. Adjust if needed.
KATHA_TO_SQFT=720
